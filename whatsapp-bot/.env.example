# Supabase (service role — server-side only, never expose in frontend)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# HTTP port (Railway sets PORT automatically)
PORT=3001

# WhatsApp session directory (use /data/whatsapp-session with Railway volume)
WHATSAPP_SESSION_PATH=./whatsapp-session

# Linux/Docker Chrome path (set automatically in Dockerfile)
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome-stable
